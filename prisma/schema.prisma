generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum TransactionType {
  IN
  OUT
}

enum TransactionReason {
  // IN reasons
  NEW_PURCHASE
  PRODUCTION
  RETURN
  // OUT reasons
  SALE
  OFFLINE_SALE
  DAMAGED
  EXPIRED
  AUDIT
}

enum MaterialTransactionType {
  IN
  OUT
}

enum MaterialTransactionReason {
  // IN reasons
  NEW_PURCHASE
  PRODUCTION_RETURN
  // OUT reasons
  PRODUCTION_USE
  ADJUSTMENT
}

enum ProductionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  VERIFYING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

// ==================== MODELS ====================

model Profile {
  id           String  @id @default(uuid())
  email        String  @unique
  password     String
  firstname    String
  lastname     String
  role         String  @default("USER")
  profileImage String?
  phonenumber  String?
  address      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders               Order[]
  materialTransactions MaterialTransaction[]
  stockTransactions    StockTransaction[]
  productSlips         ProductSlip[]
  Cart                 Cart?
}

model Product {
  Pid         Int      @id @default(autoincrement())
  productCode String?  @unique
  Pname       String
  createdAt   DateTime @default(now())

  images   ProductImage[]
  Option   ProductOption[]
  variants ProductVariant[]
  Slip     ProductSlip[]
}

model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  Pid     Int
  product Product @relation(fields: [Pid], references: [Pid], onDelete: Cascade)
}

model ProductOption {
  id   Int     @id @default(autoincrement())
  name String?

  Pid     Int
  product Product @relation(fields: [Pid], references: [Pid], onDelete: Cascade)

  values ProductOptionValue[]
}

model ProductOptionValue {
  id    Int    @id @default(autoincrement())
  value String

  optionId Int
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  variantValues ProductVariantValue[]
}

model ProductVariant {
  id    Int    @id @default(autoincrement())
  price Float?

  Pid     Int
  product Product @relation(fields: [Pid], references: [Pid], onDelete: Cascade)

  values             ProductVariantValue[]
  OrderItem          OrderItem[]
  CartItem           CartItem[]
  recipes            ProductRecipe[]
  StockTransaction   StockTransaction[]
  productionOrders   ProductionOrder[]
  productVariantLots ProductVariantLot[]
}

model ProductVariantValue {
  id Int @id @default(autoincrement())

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  optionValueId Int
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

model ProductSlip {
  id       Int    @id @default(autoincrement())
  action   String
  snapshot Json

  Pid     Int
  product Product @relation(fields: [Pid], references: [Pid], onDelete: Cascade)

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  createdAt DateTime @default(now())
}

model Material {
  id          Int     @id @default(autoincrement())
  code        String? @unique
  name        String
  unit        String
  costPerUnit Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions MaterialTransaction[]
  recipes      ProductRecipe[]
  MaterialLot  MaterialLot[]
}

model MaterialLot {
  id         Int      @id @default(autoincrement())
  lotNumber  String
  stock      Float    @default(0)
  costPerUnit Float?

  receiveDate DateTime  @default(now())
  expireDate  DateTime?

  materialId Int
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  transactions MaterialTransaction[]

  @@unique([materialId, lotNumber])
  @@index([stock, expireDate])
}

model MaterialTransaction {
  id        Int                        @id @default(autoincrement())
  type      MaterialTransactionType
  reason    MaterialTransactionReason?
  amount    Float
  totalCost Float?
  note      String?

  materialId Int
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  materialLotId Int?
  materialLot   MaterialLot? @relation(fields: [materialLotId], references: [id])

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  productionOrderId Int?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Order {
  id             String  @id @default(uuid())
  totalAmount    Float
  status         OrderStatus
  trackingNumber String?
  slipImage      String?

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([status])
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Cart {
  id String @id @default(uuid())

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id])

  items CartItem[]
}

model CartItem {
  id       String @id @default(uuid())
  quantity Int

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model ProductRecipe {
  id       Int   @id @default(autoincrement())
  quantity Float

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  materialId Int
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([variantId, materialId])
}

model ProductVariantLot {
  id          Int       @id @default(autoincrement())
  lotNumber   String
  stock       Int       @default(0)
  unitCost    Float?
  produceDate DateTime  @default(now())
  expireDate  DateTime?

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  transactions StockTransaction[]

  @@unique([variantId, lotNumber])
  @@index([variantId])
}

model StockTransaction {
  id     Int               @id @default(autoincrement())
  type   TransactionType
  reason TransactionReason?
  amount Int
  note   String?

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  variantLotId Int?
  variantLot   ProductVariantLot? @relation(fields: [variantLotId], references: [id])

  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  productionOrderId Int?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
}

model StoreSetting {
  id              String   @id @default("global")
  storeName       String   @default("Tobacco Store")
  email           String   @default("contact@tobacco.com")
  phone           String   @default("02-123-4567")
  address         String   @default("123 ถนนสุขุมวิท กรุงเทพมหานคร 10110")
  maintenanceMode Boolean  @default(false)
  bankName        String?
  accountNumber   String?
  accountName     String?
  updatedAt       DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductionOrder {
  id     Int              @id @default(autoincrement())
  docNo  String           @unique
  amount Int
  status ProductionStatus @default(PENDING)
  note   String?

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materialTransactions MaterialTransaction[]
  stockTransactions    StockTransaction[]
}